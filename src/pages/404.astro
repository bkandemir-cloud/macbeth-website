---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <section class="band">
    <div class="wrap prose center" style="padding: 4rem 0;">
      <p class="kicker">404</p>
      <h1>Nothing here yet</h1>
      <p class="lede">This page does not exist, or has not been written yet.</p>
      <p><a href="/"><strong>← Back to the home page</strong></a></p>
    </div>
  </section>
</BaseLayout>
