---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Teacher Area" mode="teacher" active="teacher-home">
  <div class="part-head">
    <div class="wrap">
      <p class="kicker">For teachers</p>
      <h1>Teacher area</h1>
    </div>
  </div>
  <section class="band">
    <div class="wrap prose">
      <p>Scheme of work, lesson sequences and assessment guidance for the Macbeth coursework unit will live here as the unit is built. The site follows the family conventions: comment-only marking culture, device-spotting always pushed to effect, and drama taught as drama.</p>
    </div>
  </section>
</BaseLayout>
